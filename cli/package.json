{
  "name": "riper-for-all",
  "version": "1.0.0",
  "description": "Universal RIPER framework for AI coding tools - Works across Cursor, Claude Code, OpenCode and more",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "riper-for-all": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs-extra'); fs.copySync('src/dashboard/public','dist/dashboard/public'); fs.chmodSync('dist/index.js', 0o755);\"",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepare": "npm run build"
  },
  "keywords": [
    "riper",
    "cursor",
    "claude-code",
    "opencode",
    "ai-coding",
    "workflow",
    "development-framework"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/riper-for-all/riper-for-all"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "conf": "^12.0.0",
    "express": "^4.18.2",
    "fs-extra": "^11.2.0",
    "inquirer": "^9.2.0",
    "ora": "^7.0.0",
    "picocolors": "^1.0.0",
    "proper-lockfile": "^4.1.2",
    "ws": "^8.18.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.9.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/express": "^5.0.6",
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^20.19.37",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
